# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org/

root = true

# Python files
[*.py]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100
charset = utf-8

# JSON files
[*.json]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

# YAML files (requirements, config, etc.)
[*.{yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

# Markdown files
[*.md]
indent_style = space
indent_size = 2
# Preserve trailing whitespace in markdown (used for line breaks)
trim_trailing_whitespace = false
insert_final_newline = true
charset = utf-8

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

# Makefile
[Makefile]
indent_style = tab
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

# TOML files
[*.toml]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8

# Text files
[*.txt]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8
